# stego-app — environment variables example
# Copy this file to .env and fill in your values

# -- app
APP_ENV=development  # development | production

#  -- api
# SSR:  el servidor Leptos llama al server directamente (red interna o local)
# CSR:  el browser llama al proxy del app (nunca al server directamente)
API_BASE_URL=http://localhost:4000         # SSR → server (local dev)
# API_BASE_URL=http://server:4000         # SSR → server (Docker)

PUBLIC_API_BASE_URL=http://localhost:3000  # CSR → proxy del app

# -- leptos
LEPTOS_OUTPUT_NAME=stego-app
LEPTOS_SITE_ROOT=site
LEPTOS_SITE_PKG_DIR=pkg
LEPTOS_SITE_ADDR=127.0.0.1:3000           # dirección donde escucha el app
LEPTOS_RELOAD_PORT=3001                   # puerto de hot-reload (dev only)
